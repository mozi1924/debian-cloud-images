#!/bin/bash
set -euE

$ROOTCMD groupadd --gid 1000 vagrant
$ROOTCMD useradd --uid 1000 --gid 1000 --shell /bin/bash vagrant
mkdir -p $target/home/vagrant/.ssh
cat > $target/home/vagrant/.ssh/authorized_keys << EOF
ssh-rsa  vagrant insecure public key
EOF
chmod -R go= $target/home/vagrant
chown -R 1000:1000 $target/home/vagrant

cat > $target/etc/sudoers.d/90-vagrant << EOF
vagrant ALL=(ALL) NOPASSWD: ALL
EOF

echo root:vagrant | $ROOTCMD chpasswd
echo vagrant:vagrant | $ROOTCMD chpasswd

# https://developer.hashicorp.com/vagrant/docs/boxes/base#ssh-tweaks
ainsl /etc/ssh/sshd_config 'UseDNS no'

$ROOTCMD systemctl enable generate-sshd-host-keys.service
